{
  "name": "serial-reader",
  "version": "0.1.0",
  "description": "Desktop app para leitura de equipamentos via porta serial, vinculada a receitas e lotes.",
  "main": "dist/main/main/index.js",
  "author": "Serial Reader",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && concurrently --raw -n MAIN,RENDERER,ELECTRON -c blue,green,yellow \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"vite\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron . --no-sandbox",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "cross-env NODE_ENV=production electron . --no-sandbox",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w serialport",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "sim:build": "tsc -p tsconfig.tools.json",
    "sim": "npm run sim:build && node dist/tools/serial-sim.js",
    "sim:test": "npm run sim:build && node dist/tools/sim-test.js"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/syne": "^5.2.7",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/sql.js": "^1.4.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.serialreader.app",
    "productName": "Serial Reader",
    "copyright": "Copyright © 2025 Serial Reader",
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/serialport/**/*",
      "**/node_modules/@serialport/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/node-gyp-build/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Serial Reader",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
