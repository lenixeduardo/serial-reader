{
  "name": "serial-reader",
  "version": "0.1.0",
  "description": "Desktop app para leitura de equipamentos via porta serial, vinculada a receitas e lotes.",
  "main": "dist/main/main/index.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n MAIN,RENDERER -c blue,green \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "cross-env NODE_ENV=production electron . --no-sandbox",
    "package": "npm run build && electron-builder",
    "rebuild": "npx prebuild-install --runtime electron --target 32.3.3 --arch x64 --download --directory node_modules/better-sqlite3 && electron-rebuild -f -w serialport",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "sim:build": "tsc -p tsconfig.tools.json",
    "sim": "npm run sim:build && node dist/tools/serial-sim.js",
    "sim:test": "npm run sim:build && node dist/tools/sim-test.js"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/syne": "^5.2.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.serialreader.app",
    "productName": "Serial Reader",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
